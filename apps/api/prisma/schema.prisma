// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  // The API bundle is CommonJS (package.json "type": "commonjs", Nest/SWC build).
  // Generate a CJS client so `node dist/main.js` can require it — the default ESM
  // client uses `import.meta.url` and cannot be required from CommonJS output.
  moduleFormat = "cjs"
  runtime      = "nodejs"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Identity & tenancy (phase-01). See docs/architecture/data-model.md and
// docs/architecture/multi-tenancy.md.
//
// Naming: TeamBrewer domain tables use snake_case columns/tables per
// api-conventions.md. The Better Auth-owned tables (user/session/account/
// verification/two_factor) keep Better Auth's native column names — the
// `@map`/`@@map` here only snake_cases them in the database; the camelCase
// Prisma field names Better Auth requires are preserved.
// ---------------------------------------------------------------------------

/// Per-team role. Instance-admin is a separate global flag on User, not a team role.
enum TeamRole {
  team_admin
  member
}

/// Purpose of an admin-generated single-use link (see accounts-and-auth.md).
enum InviteTokenPurpose {
  setup
  reset
  discord_link
}

/// A person who can log in. Global (one login, many teams). Better Auth owns the
/// core auth fields; TeamBrewer adds the domain fields below. There is no real
/// email (ADR-0003): `email` holds a synthetic, non-routable value so Better
/// Auth's schema is satisfied while login happens by `username` or Discord.
model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // two-factor plugin
  twoFactorEnabled Boolean? @default(false) @map("two_factor_enabled")

  // username plugin
  username        String? @unique
  displayUsername String? @map("display_username")

  // TeamBrewer domain fields
  displayName     String  @map("display_name")
  isInstanceAdmin Boolean @default(false) @map("is_instance_admin")
  authMethod      String  @default("password_totp") @map("auth_method")
  discordUserId   String? @unique @map("discord_user_id")
  discordUsername String? @map("discord_username")

  sessions             Session[]
  accounts             Account[]
  twoFactors           TwoFactor[]
  memberships          TeamMembership[]
  inviteTokens         InviteToken[]
  ownedDecks           Deck[]
  deckIterationEntries DeckIterationEntry[]
  attendances          Attendance[]
  authoredComments     Comment[]
  mentions             Mention[]
  notifications        Notification[]
  activityEvents       ActivityEvent[]
  loggedGameLogs       GameLog[]            @relation("GameLogLoggedBy")
  pilotedGameLogs      GameLog[]            @relation("GameLogPilot")
  opponentGameLogs     GameLog[]            @relation("GameLogOpponentPilot")

  @@map("user")
}

/// Better Auth session (secure, httpOnly cookie carries the token).
model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

/// Better Auth account: credential (password) and social (Discord) links.
model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

/// Better Auth verification tokens (used by internal flows).
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@map("verification")
}

/// Better Auth two-factor record. `backupCodes` holds the encrypted, single-use
/// recovery codes — TeamBrewer relies on Better Auth for backup-code storage.
model TwoFactor {
  id                      String    @id
  secret                  String
  backupCodes             String    @map("backup_codes")
  userId                  String    @map("user_id")
  verified                Boolean?  @default(true)
  failedVerificationCount Int?      @default(0) @map("failed_verification_count")
  lockedUntil             DateTime? @map("locked_until")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([secret])
  @@index([userId])
  @@map("two_factor")
}

/// A team is an isolated workspace bound to exactly one game (the tenant root).
model Team {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  gameId     String    @map("game_id")
  createdBy  String    @map("created_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  archivedAt DateTime? @map("archived_at")

  memberships     TeamMembership[]
  decks           Deck[]
  events          Event[]
  gauntletEntries GauntletEntry[]
  comments        Comment[]
  notifications   Notification[]
  activityEvents  ActivityEvent[]
  gameLogs        GameLog[]

  @@index([gameId])
  @@map("team")
}

/// Links a user to a team with a per-team role (the tenant link).
model TeamMembership {
  id       String   @id @default(cuid())
  teamId   String   @map("team_id")
  userId   String   @map("user_id")
  role     TeamRole
  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_membership")
}

/// A single-use, hashed, expiring link an admin generates for onboarding or
/// recovery. Only the token hash is stored; the raw token lives only in the URL.
model InviteToken {
  id        String             @id @default(cuid())
  userId    String?            @map("user_id")
  teamId    String?            @map("team_id")
  purpose   InviteTokenPurpose
  tokenHash String             @unique @map("token_hash")
  expiresAt DateTime           @map("expires_at")
  usedAt    DateTime?          @map("used_at")
  createdAt DateTime           @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose])
  @@map("invite_token")
}

// ---------------------------------------------------------------------------
// Game reference data (phase-02). Global, per-game, owned by the game adapter —
// no teamId; reads are filtered by the active team's game. Seed populates the
// network-free catalog (Game, Format); the card sync derives Hero and Card from
// the sanctioned open dataset. See docs/architecture/data-model.md and
// docs/features/card-database.md.
//
// Cards are reference data only (decks are links, ADR-0002): a lean Card stores
// just name + pitch + image — enough to reference a card via search/autocomplete
// and show its image (which already conveys the stats). No combat stats, format
// legality, or printings are stored.
// ---------------------------------------------------------------------------

/// A supported card game. `id` is a stable slug (e.g. "flesh-and-blood") that
/// Team.gameId holds; `key` is the adapter/enum key (e.g. "flesh_and_blood").
model Game {
  id        String   @id
  key       String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  formats         Format[]
  heroes          Hero[]
  cards           Card[]
  cardDataVersion CardDataVersion?
  decks           Deck[]

  @@map("game")
}

/// A play format for a game (e.g. Classic Constructed, Blitz). Reference context
/// only — TeamBrewer does not enforce legality.
model Format {
  id            String   @id @default(cuid())
  gameId        String   @map("game_id")
  key           String
  name          String
  isConstructed Boolean  @map("is_constructed")
  sortOrder     Int      @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  game     Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  decks    Deck[]
  events   Event[]
  gameLogs GameLog[]

  @@unique([gameId, key])
  @@index([gameId])
  @@map("format")
}

/// A hero/identity for a game, derived from the synced card dataset. Soft-deleted
/// (archivedAt) when it disappears upstream, never hard-deleted.
model Hero {
  id           String    @id @default(cuid())
  gameId       String    @map("game_id")
  externalId   String    @map("external_id")
  name         String
  classes      String[]
  talents      String[]
  startingLife Int?      @map("starting_life")
  imageUrl     String?   @map("image_url")
  archivedAt   DateTime? @map("archived_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  game            Game            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  decks           Deck[]
  gauntletEntries GauntletEntry[]
  gameLogs        GameLog[]

  @@unique([gameId, externalId])
  @@index([gameId, name])
  @@map("hero")
}

/// A lean card reference row (see the section note above). Unique by
/// (gameId, externalId); searchable by (gameId, name). Soft-deleted when it
/// disappears upstream so references and history survive.
model Card {
  id         String    @id @default(cuid())
  gameId     String    @map("game_id")
  externalId String    @map("external_id")
  name       String
  pitch      Int?
  imageUrl   String?   @map("image_url")
  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  game         Game          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  gameLogCards GameLogCard[]

  @@unique([gameId, externalId])
  @@index([gameId, name])
  @@map("card")
}

/// Provenance of a game's synced card data (one row per game): the sanctioned
/// source, its version, and when it was last synced. Drives "card data as of …".
model CardDataVersion {
  gameId        String   @id @map("game_id")
  sourceName    String   @map("source_name")
  sourceUrl     String   @map("source_url")
  sourceVersion String   @map("source_version")
  lastSyncedAt  DateTime @map("last_synced_at")
  cardCount     Int      @map("card_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("card_data_version")
}

// ---------------------------------------------------------------------------
// Decks (phase-03). Team-owned, link-only (ADR-0002): a deck is a hero/format +
// external link + metadata plus a manual prose iteration log — there is NO stored
// card list. Every row carries a non-null teamId and is scoped to the active team
// server-side (multi-tenancy.md). See docs/architecture/data-model.md and
// docs/features/decks.md.
// ---------------------------------------------------------------------------

/// A deck's position in its testing lifecycle. Transitions are validated
/// server-side (see docs/features/decks.md); `retired` is a reopenable terminal.
enum DeckStatus {
  exploratory
  testing
  tournament_ready
  retired
}

/// `team` = visible to all members; `private` = a personal draft visible only to
/// its owner and moderating team-admins.
enum DeckVisibility {
  team
  private
}

/// A team's deck: a link to an external list (Fabrary, etc.) plus structured,
/// aggregable metadata. `source` is the recognized link provider (URL-pattern
/// recognition only, never a content fetch). `isReference` marks an opponent/meta
/// archetype used by gauntlets. Soft-deleted via `archivedAt` so history survives.
model Deck {
  id          String         @id @default(cuid())
  teamId      String         @map("team_id")
  name        String
  gameId      String         @map("game_id")
  formatId    String         @map("format_id")
  heroId      String?        @map("hero_id")
  externalUrl String         @map("external_url")
  source      String
  ownerId     String         @map("owner_id")
  status      DeckStatus     @default(exploratory)
  visibility  DeckVisibility @default(team)
  isReference Boolean        @default(false) @map("is_reference")
  tags        String[]
  notes       String         @default("")
  archivedAt  DateTime?      @map("archived_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  game   Game   @relation(fields: [gameId], references: [id])
  format Format @relation(fields: [formatId], references: [id])
  hero   Hero?  @relation(fields: [heroId], references: [id])
  owner  User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  iterationEntries DeckIterationEntry[]
  gauntletEntries  GauntletEntry[]
  gameLogsAsDeck         GameLog[] @relation("GameLogDeck")
  gameLogsAsOpponentDeck GameLog[] @relation("GameLogOpponentDeck")

  @@index([teamId])
  @@index([teamId, status])
  @@index([teamId, heroId])
  @@index([teamId, formatId])
  @@map("deck")
}

/// One append-only entry in a deck's iteration log (a prose changelog line, e.g.
/// "-2 X, +2 Y after the event"). There is no stored card list or computed diff.
model DeckIterationEntry {
  id        String   @id @default(cuid())
  deckId    String   @map("deck_id")
  authorId  String   @map("author_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  deck   Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([deckId, createdAt])
  @@map("deck_iteration_entry")
}

// ---------------------------------------------------------------------------
// Events & gauntlets (phase-05). The Event is the central organizing hub (ADR-0004):
// a target tournament with a gauntlet (the field to beat, weighted by expected
// metagame share) and member attendance (RSVP). See
// docs/features/events-and-gauntlets.md and docs/architecture/data-model.md.
//
// Permissions are a shared team board: any member may create/edit/delete any event
// or gauntlet entry (no owner column); attendance is per-user. Event and
// GauntletEntry carry teamId and are team-scoped by construction; Attendance is
// scoped transitively through its parent event (like DeckIterationEntry).
// ---------------------------------------------------------------------------

/// An event's lifecycle. Transitions are validated server-side (see
/// docs/features/events-and-gauntlets.md); `archived` is the terminal soft-delete
/// state (reaching it stamps `archivedAt` and drops the event from default lists).
enum EventStatus {
  upcoming
  active
  completed
  archived
}

/// How much an event matters (ordinal: local < regional < national < major).
/// Drives dashboard prioritization (consumers deferred to later phases).
enum EventImportance {
  local
  regional
  national
  major
}

/// A member's RSVP for an event.
enum AttendanceStatus {
  going
  maybe
  not_going
}

/// A team's target tournament: format + date + importance, with a lifecycle status.
/// The hub that later modules (game logging, matchups, assignments, deck selection)
/// optionally reference. Soft-deleted via `archivedAt` so history survives.
model Event {
  id          String          @id @default(cuid())
  teamId      String          @map("team_id")
  name        String
  formatId    String          @map("format_id")
  date        DateTime
  location    String?
  importance  EventImportance
  description String          @default("")
  status      EventStatus     @default(upcoming)
  archivedAt  DateTime?       @map("archived_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  format Format @relation(fields: [formatId], references: [id])

  gauntletEntries GauntletEntry[]
  attendances     Attendance[]
  gameLogs        GameLog[]

  @@index([teamId])
  @@index([teamId, status])
  @@index([teamId, formatId])
  @@index([teamId, importance])
  @@map("event")
}

/// One entry in an event's gauntlet (the field to beat). Names exactly one target
/// form — a reference deck (a Deck where isReference is true), a bare hero, or a
/// free-text archetype label — plus its projected field share (0–100, stored raw;
/// normalization into weights is deferred to consumers). The exactly-one-target and
/// duplicate-target rules are enforced server-side.
model GauntletEntry {
  id                String   @id @default(cuid())
  eventId           String   @map("event_id")
  teamId            String   @map("team_id")
  referenceDeckId   String?  @map("reference_deck_id")
  heroId            String?  @map("hero_id")
  archetypeLabel    String?  @map("archetype_label")
  expectedMetaShare Int      @map("expected_meta_share")
  notes             String   @default("")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  event         Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  team          Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  referenceDeck Deck? @relation(fields: [referenceDeckId], references: [id], onDelete: SetNull)
  hero          Hero? @relation(fields: [heroId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([teamId])
  @@map("gauntlet_entry")
}

/// A member's RSVP for an event (one row per member per event). No teamId — it is
/// reached only through its team-scoped parent event. Retained for history even if
/// the member later leaves the team.
model Attendance {
  id        String           @id @default(cuid())
  eventId   String           @map("event_id")
  userId    String           @map("user_id")
  status    AttendanceStatus
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("attendance")
}

// ---------------------------------------------------------------------------
// Game logging (phase-06). A GameLog records one game/match between two sides
// plus the structured confidence factors that derive a server-authoritative
// confidenceWeight (ADR-0005; the derivation lives in packages/shared). It is the
// source of truth for every matchup aggregate (phase-07). Team-scoped by teamId;
// the logger (loggedById) and team-admins may edit/archive. Soft-deleted via
// archivedAt. See docs/features/game-logging.md and docs/architecture/data-model.md.
// ---------------------------------------------------------------------------

/// Which side took the first turn (going first matters for FaB matchups).
enum GameSide {
  A
  B
}

/// How a win was achieved (optional tag; does not affect the confidence weight).
enum WinType {
  life_to_zero
  on_time
  opponent_concede
  deck_out
}

/// Why a game was lost (optional tag; does not affect the confidence weight).
enum LossReason {
  outplayed
  misplay
  on_time
  mismatch
  variance
  deck_out
}

/// Confidence factor: how evenly matched the two pilots were.
enum SkillParity {
  evenly_matched
  minor_gap
  major_gap
}

/// Confidence factor: how serious/focused the games were.
enum Seriousness {
  tournament_serious
  focused_practice
  casual
}

/// Confidence factor: how tuned/final both decks were.
enum DeckMaturity {
  both_tuned
  partially_tuned
  experimental
}

/// Confidence factor: how well the pilot knew the deck.
enum PilotFamiliarity {
  knows_well
  learning
  first_time
}

/// One recorded game/match. sideA is always our side (a team-member pilot on a team
/// deck); sideB is either a teammate (opponentPilotUserId + opponentDeckId) or an
/// external opponent identified by exactly one of a reference deck, a hero, or a
/// free-text archetype label. Opponent identifier rules are enforced server-side;
/// confidenceWeight is derived from the four factor columns (never client-supplied).
model GameLog {
  id                   String    @id @default(cuid())
  teamId               String    @map("team_id")
  loggedById           String    @map("logged_by_id")
  formatId             String    @map("format_id")
  eventId              String?   @map("event_id")
  playedAt             DateTime  @map("played_at")

  // side A — our side
  pilotUserId          String    @map("pilot_user_id")
  deckId               String    @map("deck_id")

  // side B — opponent (teammate or external)
  opponentPilotUserId  String?   @map("opponent_pilot_user_id")
  externalOpponentName String?   @map("external_opponent_name")
  opponentDeckId       String?   @map("opponent_deck_id")
  heroId               String?   @map("hero_id")
  archetypeLabel       String?   @map("archetype_label")

  firstPlayerSide      GameSide    @map("first_player_side")
  bestOf               Int         @map("best_of")
  gamesWonA            Int         @map("games_won_a")
  gamesWonB            Int         @map("games_won_b")
  winType              WinType?    @map("win_type")
  lossReason           LossReason? @map("loss_reason")
  learnings            String      @default("")

  // confidence factors (ADR-0005) → confidenceWeight
  skillParity          SkillParity      @map("skill_parity")
  seriousness          Seriousness      @map("seriousness")
  deckMaturity         DeckMaturity     @map("deck_maturity")
  pilotFamiliarity     PilotFamiliarity @map("pilot_familiarity")
  confidenceWeight     Float            @map("confidence_weight")

  archivedAt           DateTime? @map("archived_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  team          Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  loggedBy      User   @relation("GameLogLoggedBy", fields: [loggedById], references: [id], onDelete: Cascade)
  format        Format @relation(fields: [formatId], references: [id])
  event         Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)
  pilot         User   @relation("GameLogPilot", fields: [pilotUserId], references: [id], onDelete: Cascade)
  deck          Deck   @relation("GameLogDeck", fields: [deckId], references: [id], onDelete: Cascade)
  opponentPilot User?  @relation("GameLogOpponentPilot", fields: [opponentPilotUserId], references: [id], onDelete: SetNull)
  opponentDeck  Deck?  @relation("GameLogOpponentDeck", fields: [opponentDeckId], references: [id], onDelete: SetNull)
  hero          Hero?  @relation(fields: [heroId], references: [id], onDelete: SetNull)
  cards         GameLogCard[]

  @@index([teamId])
  @@index([teamId, formatId])
  @@index([teamId, eventId])
  @@index([teamId, deckId])
  @@index([teamId, heroId])
  @@index([teamId, pilotUserId])
  @@index([teamId, opponentDeckId])
  @@index([teamId, opponentPilotUserId])
  @@map("game_log")
}

/// Whether a card over- or under-performed in a logged game.
enum GameLogCardRole {
  impressive
  underperforming
}

/// Whose card it was in the game.
enum GameLogCardSide {
  ours
  theirs
}

/// A card reference captured on a game log (impressive/underperforming, tagged by
/// side). Like Attendance, it carries no teamId — it is reached only through its
/// team-scoped parent GameLog. Cards come from the global card DB (decks are
/// links, ADR-0002); the referenced card must belong to the team's game.
model GameLogCard {
  id        String          @id @default(cuid())
  gameLogId String          @map("game_log_id")
  cardId    String          @map("card_id")
  role      GameLogCardRole
  side      GameLogCardSide
  createdAt DateTime        @default(now()) @map("created_at")

  gameLog GameLog @relation(fields: [gameLogId], references: [id], onDelete: Cascade)
  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([gameLogId])
  @@index([cardId])
  @@map("game_log_card")
}

// ---------------------------------------------------------------------------
// Collaboration core (phase-04). A polymorphic, team-scoped subsystem any module
// attaches to by addressing a subject as (subject_type, subject_id). See
// docs/features/collaboration-core.md and docs/architecture/data-model.md.
//
// `subject_type`, notification `type`, and activity `verb` are stored as plain
// strings (not Postgres enums) so the set can be extended as modules adopt the
// subsystem without a DB migration; the shared Zod enums validate the values at
// the HTTP boundary.
// ---------------------------------------------------------------------------

/// A polymorphic, threaded comment on any subject. Single-level threading:
/// `parentCommentId` points at a top-level comment (a reply to a reply is
/// flattened onto the same parent server-side). Soft-deleted via `archivedAt` so
/// the thread structure survives (rendered as "removed").
model Comment {
  id              String    @id @default(cuid())
  teamId          String    @map("team_id")
  authorId        String    @map("author_id")
  subjectType     String    @map("subject_type")
  subjectId       String    @map("subject_id")
  body            String
  parentCommentId String?   @map("parent_comment_id")
  archivedAt      DateTime? @map("archived_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  team          Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentComment Comment?       @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies       Comment[]      @relation("CommentReplies")
  mentions      Mention[]
  notifications Notification[]

  @@index([teamId, subjectType, subjectId, createdAt])
  @@index([parentCommentId])
  @@map("comment")
}

/// An `@handle` mention parsed from a comment body, resolved to an in-team member.
/// Not team-scoped directly — it is reached only through its comment. Each mention
/// of a distinct member produces one Notification.
model Mention {
  id              String   @id @default(cuid())
  commentId       String   @map("comment_id")
  mentionedUserId String   @map("mentioned_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  comment       Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser User    @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@unique([commentId, mentionedUserId])
  @@index([mentionedUserId])
  @@map("mention")
}

/// The recipient's in-app inbox item (there is no email/push — ADR-0003). Scoped
/// to a team and to a single `userId`; `readAt` null means unread. Links back to
/// its subject and (for mention notifications) the originating comment.
model Notification {
  id          String    @id @default(cuid())
  teamId      String    @map("team_id")
  userId      String    @map("user_id")
  type        String
  subjectType String    @map("subject_type")
  subjectId   String    @map("subject_id")
  commentId   String?   @map("comment_id")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  team    Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([teamId, userId, readAt])
  @@index([teamId, userId, createdAt])
  @@map("notification")
}

/// An append-only entry in the team activity feed, addressed polymorphically.
/// Produced by modules as meaningful things happen (e.g. a deck was created, a
/// teammate commented).
model ActivityEvent {
  id          String   @id @default(cuid())
  teamId      String   @map("team_id")
  actorId     String   @map("actor_id")
  verb        String
  subjectType String   @map("subject_type")
  subjectId   String   @map("subject_id")
  createdAt   DateTime @default(now()) @map("created_at")

  team  Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
  @@index([teamId, subjectType, subjectId, createdAt])
  @@map("activity_event")
}
