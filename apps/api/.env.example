# Variables for local (non-Docker) API development. Copy to apps/api/.env.
# Read by NestJS ConfigModule at runtime and by the Prisma CLI via
# prisma.config.ts (dotenv). This .env is git-ignored; this example is committed.

# Postgres connection string. Point it at a local Postgres, e.g. one started
# with `docker compose up postgres`.
DATABASE_URL=postgresql://teambrewer:teambrewer@localhost:5432/teambrewer

# Port the API listens on.
API_PORT=3000

# Web app origin allowed by CORS (the Vite dev server default).
WEB_ORIGIN=http://localhost:5173

# --- Authentication (Better Auth) ---
# Secret used to sign sessions and tokens. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL where the API (and Better Auth's handlers) are reachable.
# Dev: the API's own origin. Prod: your HTTPS domain (e.g. https://teambrewer.example).
BETTER_AUTH_URL=http://localhost:3000

# --- Discord SSO (see ADR-0009 and docs/architecture/security.md) ---
# From the Discord Developer Portal -> your application -> OAuth2. We request
# ONLY the `identify` scope (no email). The Client Secret is sensitive: keep it
# only in .env (git-ignored) and never commit it.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must EXACTLY match a redirect URL registered in the portal. Better Auth's
# Discord callback is <BETTER_AUTH_URL>/api/auth/callback/discord.
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback/discord
# The Discord CLAIM / identity-link flow uses a second, custom callback that must
# ALSO be registered in the portal: <BETTER_AUTH_URL>/api/discord/callback

# --- Card data sync (phase-02, the-fab-cube) -----------------------------
# Pinned the-fab-cube release tag the FaB card sync fetches. Bump this to adopt
# a newer dataset. Default: v8.2.0
FAB_CARDS_REF=v8.2.0

# Full override for the dataset URL (e.g. a local mirror or fixture). When unset
# it is derived from FAB_CARDS_REF against raw.githubusercontent.com.
# FAB_CARDS_URL=

# Set to "true" to register the scheduled (cron) card sync. Off by default so
# tests, the CLI, and local dev never run a background sync.
# CARD_SYNC_ENABLED=false

# Cron expression for the scheduled sync when enabled. Default: daily at 04:00.
# CARD_SYNC_CRON=0 4 * * *
