# Variables read by Docker Compose (`docker compose up`). Copy to .env and edit.
# The root .env is git-ignored; this example is committed.

# Postgres superuser password for the bundled database service.
POSTGRES_PASSWORD=teambrewer

# Host port the web service (Nginx) is published on.
WEB_PORT=8080

# Origin the API allows via CORS. Must match how you reach the web app. Behind
# the TLS front proxy this is your public HTTPS origin, e.g. https://teambrewer.example.
WEB_ORIGIN=http://localhost:8080

# --- Authentication (Better Auth) ---
# REQUIRED. Signs sessions and tokens. Generate one with: openssl rand -base64 32
# The API will refuse to start if this is unset.
BETTER_AUTH_SECRET=
# Public base URL where the app (and Better Auth's handlers) are reachable.
# Behind the TLS front proxy, your HTTPS domain, e.g. https://teambrewer.example.
BETTER_AUTH_URL=http://localhost:8080

# --- Discord SSO (optional; see ADR-0009) ---
# Leave blank to disable Discord login. The secret is sensitive — never commit it.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

# --- Rate limiting (optional overrides; code defaults apply when unset) ---
# Windows are in ms for the Nest throttler, in seconds for the Better Auth limiter.
# Global default (per client / 60s):
RATE_LIMIT_DEFAULT_LIMIT=300
# RATE_LIMIT_DEFAULT_WINDOW_MS=60000
# Strict limit for link generation/consumption + Discord OAuth start:
RATE_LIMIT_STRICT_LIMIT=20
# RATE_LIMIT_STRICT_WINDOW_MS=60000
# Expensive reads (matchup matrix/coverage) + admin card sync:
RATE_LIMIT_EXPENSIVE_LIMIT=60
# RATE_LIMIT_EXPENSIVE_WINDOW_MS=60000
# Better Auth surface (/api/auth/*): global and per sign-in path:
RATE_LIMIT_AUTH_MAX=300
# RATE_LIMIT_AUTH_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_SIGN_IN_MAX=10
# RATE_LIMIT_AUTH_SIGN_IN_WINDOW_SECONDS=60

# --- Least-privilege database user (optional; see docs/ops/self-hosting.md) ---
# By default the API connects as the Postgres superuser (composed into
# DATABASE_URL inside docker-compose.yml). To run the app as a least-privileged
# role, follow the runbook to create it, then override the API's DATABASE_URL.

# Note: the API's DATABASE_URL is composed inside docker-compose.yml from
# POSTGRES_PASSWORD. For local (non-Docker) development, see apps/api/.env.example.
