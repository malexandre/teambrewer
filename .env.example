# Variables read by Docker Compose (`docker compose up`). Copy to .env and edit.
# The root .env is git-ignored; this example is committed.

# Postgres superuser password for the bundled database service.
POSTGRES_PASSWORD=teambrewer

# Host port the web service (Nginx) is published on.
WEB_PORT=8080

# Origin the API allows via CORS. Should match how you reach the web app.
WEB_ORIGIN=http://localhost:8080

# Note: the API's DATABASE_URL is composed inside docker-compose.yml from
# POSTGRES_PASSWORD. For local (non-Docker) development, see apps/api/.env.example.
